# Copy this to .env to configure backend
# Remove the # from lines you want to use

# Server settings
HOST=127.0.0.1
PORT=8000

# Database Configuration - Using SQLite (easy setup)
DATABASE_URL=sqlite:///./lunadx.db
# For PostgreSQL (production): postgresql://user:password@localhost/database

# AI Services
GROQ_API_KEY=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
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Model settings
