# Production Environment Configuration
# Copy this to .env for production deployment

# Server settings
HOST=0.0.0.0
PORT=8000

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://lunadx:password@localhost:5432/lunadx

# Alternative: SQLite for development
# DATABASE_URL=sqlite:///./lunadx.db

# AI Services
GROQ_API_KEY=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
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Model settings
MODEL_PATH=models/chexnet.pth
SIMULATION_MODE=false

# JWT Settings (CHANGE IN PRODUCTION)
SECRET_KEY=lunadx-super-secret-key-change-in-production-unique-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# CORS settings
ALLOW_ORIGINS=["http://localhost:8080", "http://127.0.0.1:8080"]

# Production settings
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# File upload settings
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.dcm

# Security
BCRYPT_ROUNDS=12
JWT_ALGORITHM=HS256

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
