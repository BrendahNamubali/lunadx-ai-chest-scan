# Environment variables for LunaDX Backend
# Copy this to .env and fill in your API keys if desired

# Server settings
HOST=127.0.0.1
PORT=8000

# AI API Keys (optional - if not provided, will use template-based reports)
# ANTHROPIC_API_KEY=your_anthropic_key_here
# GROQ_API_KEY=your_groq_key_here

# Model settings
MODEL_PATH=models/chexnet.pth
SIMULATION_MODE=true

# CORS settings
ALLOW_ORIGINS=["http://localhost:8080", "http://127.0.0.1:8080"]
